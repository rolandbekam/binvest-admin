# ═══════════════════════════════════════════════════════
# B-INVEST ADMIN — Variables d'environnement
# Copiez ce fichier en .env.local pour le développement
# Ne JAMAIS committer .env.local sur GitHub
# ═══════════════════════════════════════════════════════

# ── Supabase ────────────────────────────────────────────
# URL du projet (publique, ok dans le code)
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_PROJET.supabase.co

# Clé anonyme (publique - lecture seule côté client)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ⚠️  SERVICE ROLE KEY — STRICTEMENT SERVEUR
# Ne jamais exposer côté client — donne accès total à la DB
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Sécurité JWT ────────────────────────────────────────
# Générer avec: openssl rand -base64 64
# Minimum 32 caractères, idéalement 64+
JWT_SECRET=VOTRE_SECRET_JWT_TRES_LONG_ET_ALEATOIRE_MINIMUM_64_CHARS

# ── Pepper pour les mots de passe ───────────────────────
# Générer avec: openssl rand -base64 32
# Ajouter au hash bcrypt pour une sécurité supplémentaire
PASSWORD_PEPPER=VOTRE_PEPPER_ALEATOIRE_32_CHARS

# ── Chiffrement données sensibles (numéros ID) ──────────
# Utilisé par pgcrypto dans Supabase
ENCRYPTION_KEY=VOTRE_CLE_CHIFFREMENT_32_CHARS

# ── Email (notifications) ───────────────────────────────
# Pour envoyer les accusés de réception automatiquement
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=notifications@binvest.ng
SMTP_PASS=votre_app_password

# ── URLs ────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://admin.binvest.ng
# En développement: NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Mode ────────────────────────────────────────────────
NODE_ENV=production
